{
  "name": "zq-ui-workspace",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "description": "ZQ-UI monorepo：组件库、Playground 与文档",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "lint:check": "eslint . --ext .vue,.ts,.tsx --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,vue,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,css,md,json}\"",
    "prepare": "husky",
    "quality:check": "pnpm format:check && pnpm lint:check && pnpm typecheck && pnpm test:run",
    "pack:dry-run": "npm pack --dry-run ./packages/zq-ui --cache ./.npm-cache && npm pack --dry-run ./packages/zq-m --cache ./.npm-cache",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "publish:zq-ui": "pnpm --filter @zqzz/zq-ui publish --access public",
    "publish:zq-m": "pnpm --filter @zqzz/zq-m publish --access public",
    "publish:packages": "pnpm run publish:zq-ui && pnpm run publish:zq-m"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "element-plus": "~2.13.7",
    "vant": "^4.9.0",
    "vue": "^3.5.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "eslint-plugin-vue": "^9.20.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitepress": "^1.0.0",
    "vitest": "^1.4.0",
    "vue-tsc": "^2.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix --max-warnings 0 --ignore-pattern '!docs/.vitepress/' --ignore-pattern '!docs/.vitepress/**'",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
