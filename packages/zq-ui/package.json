{
  "name": "zq-ui",
  "version": "0.0.1",
  "description": "ZQ-UI - 基于 Element Plus 的团队自定义组件库",
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "require": "./index.ts",
      "types": "./index.ts"
    },
