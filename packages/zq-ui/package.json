      "import": "./styles/index.ts"
    },
    "./styles/*": "./styles/*"
  },
  "peerDependencies": {
    "element-plus": "^2.13.7",
    "vue": "^3.5.0"
  },
  "keywords": ["vue", "vue3", "element-plus", "component-library", "ui"],
  "license": "MIT"
}
