{
  "name": "zq-ui",
  "version": "0.0.1",
  "description": "ZQ-UI - 基于 Element Plus 的团队自定义组件库",
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "require": "./index.ts",
      "types": "./index.ts"
    },
    "./styles": {
      "import": "./styles/index.ts"
    },
    "./styles/themes": {
      "import": "./styles/themes/index.ts"
    },
    "./theme": {
      "import": "./theme.ts",
      "types": "./theme.ts"
    },
    "./styles/*": "./styles/*"
  },
  "peerDependencies": {
    "element-plus": ">=2.13.7 <2.14.0",
    "vue": "^3.5.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "element-plus",
    "component-library",
    "ui"
  ],
  "license": "MIT"
}
