{
  "name": "@zqzz/zq-ui",
  "version": "0.1.0",
  "description": "基于 Element Plus 的 Vue 3 组件库（源码分发）",
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "types": "index.ts",
  "files": [
    "components",
    "styles",
    "theme",
    "index.ts",
    "README.md",
    "!**/__tests__/**",
    "!**/*.test.ts",
    "!**/*.spec.ts"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./styles": {
      "import": "./styles/index.ts"
    },
    "./styles/themes": {
      "import": "./styles/themes/index.ts"
    },
    "./theme": {
      "import": "./theme/index.ts",
      "types": "./theme/index.ts"
    },
    "./styles/*": "./styles/*"
  },
  "peerDependencies": {
    "element-plus": ">=2.13.7 <2.14.0",
    "vue": "^3.5.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "element-plus",
    "component-library",
    "ui",
    "zq-ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zqzz-org/zq-ui.git",
    "directory": "packages/zq-ui"
  },
  "homepage": "https://crazily6617.github.io/zq-ui/",
  "bugs": {
    "url": "https://github.com/zqzz-org/zq-ui/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
